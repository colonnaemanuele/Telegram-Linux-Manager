# Telegram Bot Token - Get from @BotFather on Telegram
# IMPORTANT: Never commit your actual token to git!
TOKEN = ""

# User Mapping - Map Telegram user IDs to Linux usernames
# Format: telegram_id:linux_username,telegram_id:linux_username
# Example: USER_MAPPING = "123456789:user1,987654321:user2"
USER_MAPPING = ""

# Scripts directory (optional, defaults to 'scripts')
SCRIPTS_DIR = "scripts"

# Process tracking file (optional)
PROCESSES_FILE = "nohup_processes.txt"